{
  "name": "0001-website",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run fetch-notion && bun run fetch-open-source && vite build",
    "fetch-notion": "bun run scripts/fetch-notion.ts",
    "fetch-open-source": "bun run scripts/fetch-open-source.ts",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler pages deploy dist --project-name=0001-website",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "convex": "^1.17.0",
    "@notionhq/client": "^2.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
